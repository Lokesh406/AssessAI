MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-grading?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=your_jwt_secret_key_here_make_it_long
OPENROUTER_API_KEY=your_openrouter_api_key
NODE_ENV=development

# Comma-separated list of allowed frontend origins (include your Vercel domain in production)
# Example: FRONTEND_URLS=https://your-app.vercel.app,http://localhost:3000
FRONTEND_URLS=http://localhost:3000

# Legacy fallback (optional)
FRONTEND_URL=http://localhost:3000

# Code execution engine (Piston)
# Public Piston API is authorization-gated as of Feb 15, 2026.
# Recommended: run Piston locally via Docker and set:
# PISTON_API_URL=http://localhost:2000/api/v2/execute
PISTON_API_URL=

# Optional: if you have an authorization token for the public API
PISTON_API_TOKEN=
